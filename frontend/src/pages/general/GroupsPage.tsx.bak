  useState,
  useEffect,
  useRef,
  useCallback,
  useMemo,
  type FormEvent,
  type KeyboardEvent,
  type ClipboardEvent,
  type ChangeEvent,
} from 'react';
import { Socket } from 'socket.io-client';
import {
  PaperAirplaneIcon,
  MagnifyingGlassIcon,
  UserGroupIcon,
  XMarkIcon,
  PaperClipIcon,
  ChevronUpIcon,
  ChevronDownIcon,
  ArrowUturnLeftIcon,
  ChatBubbleLeftRightIcon,
  ClockIcon,
  DocumentIcon,
  PlusIcon,
  GlobeAltIcon,
  ComputerDesktopIcon,
  UserPlusIcon,
  TrashIcon,
} from '@heroicons/react/24/outline';
import toast from 'react-hot-toast';
import Swal from 'sweetalert2';
