## SDKs & Code Examples

### JavaScript / Node.js

```javascript
const SoftAware = require('softaware-sdk');

const client = new SoftAware({
  apiKey: 'sk_live_abc123...',
  baseUrl: 'https://api.softaware.net.za'
});

// Get profile
const profile = await client.profile.get();
console.log(profile.user.email);

// Get credit balance
const balance = await client.credits.getBalance();
console.log(`Credits: ${balance.balance}`);

// Send AI chat request
const response = await client.ai.chat({
  messages: [
    { role: 'user', content: 'Hello, AI!' }
  ],
  model: 'gpt-4o-mini'
});
console.log(response.content);
```

### Python

```python
from softaware import SoftAware

client = SoftAware(api_key='sk_live_abc123...')

# Get profile
profile = client.profile.get()
print(profile['user']['email'])

# Get credit balance
balance = client.credits.get_balance()
print(f"Credits: {balance['balance']}")

# Send AI chat request
response = client.ai.chat(
    messages=[
        {'role': 'user', 'content': 'Hello, AI!'}
    ],
    model='gpt-4o-mini'
)
print(response['content'])
```

