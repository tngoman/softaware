# Server
PORT=8787
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=1h

# Default AI provider (glm | ollama)
DEFAULT_AI_PROVIDER=ollama

# SoftAware routing for multimodal (vision) requests (glm | ollama)
# If not set, backend will try Ollama (if configured) then GLM.
SOFTAWARE_VISION_PROVIDER=ollama

# Ollama settings
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b
LEADS_OLLAMA_MODEL=qwen2.5:7b-instruct

# Ollama vision-capable model (small recommendation)
OLLAMA_VISION_MODEL=moondream

# Optional: GLM vision model override (only if you use GLM for vision)
GLM_VISION_MODEL=

# Database
# For local docker-compose below:
DATABASE_URL="mysql://softaware:softaware@localhost:3306/softaware"

# Payment Gateway - Yoco
# Get your secret key from: https://online.yoco.com/settings/api
YOCO_SECRET_KEY=your_yoco_secret_key_here
YOCO_WEBHOOK_SECRET=your_random_webhook_secret_here
# Public URL for your frontend (for payment redirects)
FRONTEND_URL=http://localhost:3001

# Payment Gateway - PayFast (Optional)
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
